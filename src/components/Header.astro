---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import Search from './Search.astro';
---

<header>
	<nav>
		<div class="brand">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<div class="nav-right">
			<div class="internal-links">
				<HeaderLink href="/">首页</HeaderLink>
				<HeaderLink href="/blog">文章</HeaderLink>
				<HeaderLink href="/about">关于</HeaderLink>
			</div>
			<Search />
			<button id="theme-toggle" class="theme-toggle" aria-label="切换主题" title="切换深色/浅色模式">
				<svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
				<svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
			</button>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		margin: 0;
		padding: 0 1em;
		background: color-mix(in srgb, var(--bg) 85%, transparent);
		backdrop-filter: saturate(180%) blur(12px);
		-webkit-backdrop-filter: saturate(180%) blur(12px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		height: 60px;
	}
	.brand a {
		font-weight: 700;
		font-size: 1.05em;
		color: var(--text);
		text-decoration: none;
		letter-spacing: -0.01em;
	}
	.brand a:hover {
		text-decoration: none;
		color: var(--accent);
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.2em;
	}
	.internal-links :global(a) {
		padding: 0.5em 0.8em;
		color: var(--text-secondary);
		text-decoration: none;
		border-radius: 8px;
		font-size: 0.95em;
		transition: color 0.15s ease, background-color 0.15s ease;
	}
	.internal-links :global(a:hover) {
		color: var(--text);
		background: var(--bg-hover);
		text-decoration: none;
	}
	.internal-links :global(a.active) {
		color: var(--accent);
		font-weight: 600;
	}
	.theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		padding: 0;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 8px;
		color: var(--text-secondary);
		cursor: pointer;
		transition: all 0.15s ease;
	}
	.theme-toggle:hover {
		background: var(--bg-hover);
		color: var(--text);
		border-color: var(--border-strong);
	}
	.icon-sun {
		display: none;
	}
	.icon-moon {
		display: block;
	}
	:global(html.dark) .icon-sun {
		display: block;
	}
	:global(html.dark) .icon-moon {
		display: none;
	}
</style>

<script>
	// 主题切换
	const toggle = document.getElementById('theme-toggle');
	function applyTheme(theme: string) {
		if (theme === 'dark') {
			document.documentElement.classList.add('dark');
		} else {
			document.documentElement.classList.remove('dark');
		}
	}
	// 初始化：localStorage 优先，否则跟随系统
	const saved = localStorage.getItem('theme');
	if (saved) {
		applyTheme(saved);
	} else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
		applyTheme('dark');
	}
	toggle?.addEventListener('click', () => {
		const isDark = document.documentElement.classList.contains('dark');
		const next = isDark ? 'light' : 'dark';
		applyTheme(next);
		localStorage.setItem('theme', next);
	});
</script>
